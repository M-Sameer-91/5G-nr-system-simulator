function generate_final_report(metrics, cfg, totalHO)
    T = size(metrics.throughput_dl, 2);
    N = size(metrics.throughput_dl, 1);

    avg_dl = mean(metrics.throughput_dl, 2);
    avg_ul = mean(metrics.throughput_ul, 2);
    avg_sinr = mean(metrics.sinr_dl, 2);
    avg_lat  = mean(metrics.latency, 2);
    harq_rtx = sum(metrics.harq_status==1,'all');
    harq_drp = sum(metrics.harq_status==2,'all');
    dc_frac  = mean(metrics.dc_active(:));

    fprintf('\n====================================================\n');
    fprintf('          5G NR SIMULATION FINAL REPORT\n');
    fprintf('====================================================\n');
    fprintf('Cells: %d | Users: %d | Duration: %d ms\n', cfg.numCells, cfg.numUsers, T);
    fprintf('Frequency: %.1f GHz | BW: %d MHz | MIMO: %dx%d\n', ...
        cfg.fc_GHz, cfg.bandwidth_MHz, cfg.N_bs_ant, cfg.N_ue_ant);
    fprintf('----------------------------------------------------\n');
    fprintf('DL Throughput  — Mean: %6.2f Mbps | Median: %6.2f Mbps\n', mean(avg_dl), median(avg_dl));
    fprintf('               — 5th pct (cell-edge): %.2f Mbps\n', prctile(avg_dl,5));
    fprintf('               — 95th pct (peak):     %.2f Mbps\n', prctile(avg_dl,95));
    fprintf('UL Throughput  — Mean: %6.2f Mbps\n', mean(avg_ul));
    fprintf('SINR           — Mean: %5.1f dB | 5th pct: %.1f dB\n', mean(avg_sinr), prctile(avg_sinr,5));
    fprintf('Latency        — Mean: %5.2f ms | 95th pct: %.1f ms\n', mean(avg_lat), prctile(avg_lat,95));
    fprintf('Handovers      — Total: %d (%.2f/user)\n', totalHO, totalHO/cfg.numUsers);
    fprintf('HARQ           — Retransmissions: %d | Drops: %d\n', harq_rtx, harq_drp);
    fprintf('Dual Conn      — Active fraction: %.1f%%\n', dc_frac*100);
    fprintf('Jain Fairness  — %.4f\n', jain_fairness(avg_dl));
    fprintf('====================================================\n');

    % Per-slice breakdown
    fprintf('\nPer-Slice Performance:\n');
    fprintf('  %-8s | DL Mbps | SINR dB | Latency ms\n','Slice');
    sliceNames = {'eMBB','URLLC','mMTC'};
    for s = 1:3
        uids = find(arrayfun(@(i) metrics.throughput_dl(i,1)>=0, 1:N));
        % Use modular assignment matching init_network
        uids_s = mod((1:N)-1,3)+1 == s;
        if any(uids_s)
            fprintf('  %-8s | %7.2f | %7.1f | %10.2f\n', sliceNames{s}, ...
                mean(avg_dl(uids_s)), mean(avg_sinr(uids_s)), mean(avg_lat(uids_s)));
        end
    end
end

function J = jain_fairness(tput)
    J = sum(tput)^2 / (length(tput)*sum(tput.^2)+1e-10);
end



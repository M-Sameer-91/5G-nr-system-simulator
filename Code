% =========================================================================
%  NETWORK INITIALIZATION
% =========================================================================
function [cells, users] = init_network_complete(cfg)
    centers = generate_hex_grid(cfg.numCells, cfg.cellRadius * sqrt(3));

    for c = 1:cfg.numCells
        cells(c).id       = c;
        cells(c).position = centers(c,:);
        cells(c).radius   = cfg.cellRadius;
        for s = 1:3
            cells(c).sectors(s).azimuth   = 120*(s-1);
            cells(c).sectors(s).gain      = 18;
            cells(c).sectors(s).beamwidth = 65;
        end
        cells(c).totalRBs     = cfg.numRBs;
        cells(c).allocatedRBs = zeros(1, cfg.numRBs);
        cells(c).load         = 0;
    end

    userIdx = 1;
    trafficTypeList = {'embb','urllc','mmtc'};
    for c = 1:cfg.numCells
        for u = 1:cfg.usersPerCell
            angle    = 2*pi*rand();
            radius   = cfg.cellRadius * sqrt(rand());
            position = cells(c).position + [radius*cos(angle), radius*sin(angle)];
            speed    = randsample(cfg.speed, 1, true, cfg.speedProb);
            velocity = speed * [cos(angle+pi/2), sin(angle+pi/2)];
            tType    = trafficTypeList{randi(3)};

            users(userIdx).id             = userIdx;
            users(userIdx).position       = position;
            users(userIdx).velocity       = velocity;
            users(userIdx).servingCell    = c;
            users(userIdx).servingSector  = randi(3);
            users(userIdx).trafficType    = tType;
            users(userIdx).buffer         = 0;
            users(userIdx).slice          = determine_slice(tType);
            users(userIdx).trafficState   = 1;
            users(userIdx).trafficTimer   = 0;
            users(userIdx).shadowFading   = cfg.shadowStd * randn(1, cfg.numCells);

            % HARQ
            users(userIdx).harq.nextProcess = 1;
            users(userIdx).harq.retxCount   = zeros(1, cfg.harqProcesses);
            users(userIdx).harq.irBuffer    = zeros(1, cfg.harqProcesses);
            for p = 1:cfg.harqProcesses
                users(userIdx).harq.processes{p} = struct('active',0,'ndi',0,'rv',0,'timer',0);
            end

            % Handover
            users(userIdx).ho = struct('state','NORMAL','tttCounter',0, ...
                'targetCell',[],'x2Timer',0);

            % CSI
            users(userIdx).csi = struct('sinr_dl',0,'sinr_ul',0,'cqi',10,'ri',1,'pmi',1);

            % QoS
            users(userIdx).qos = struct('throughput_dl',0,'throughput_ul',0, ...
                'latency',0,'packetDrop',0,'fairnessMetric',0);

            % DC
            users(userIdx).dc_active = false;
            users(userIdx).lte_sinr  = 0;

            userIdx = userIdx + 1;
        end
    end
    fprintf('Initialized %d cells, %d users\n', cfg.numCells, cfg.numUsers);
end

function centers = generate_hex_grid(n, R)
    centers    = zeros(n,2);
    centers(1,:) = [0,0];
    if n==1, return; end
    dirs = [R,0; R/2,R*sqrt(3)/2; -R/2,R*sqrt(3)/2; -R,0; -R/2,-R*sqrt(3)/2; R/2,-R*sqrt(3)/2];
    idx  = 2; ring = 1;
    while idx <= n
        x = -ring*dirs(1,1); y = -ring*dirs(1,2);
        for s = 1:6
            for step = 1:ring
                if idx>n, break; end
                centers(idx,:) = [x,y]; idx=idx+1;
                x=x+dirs(s,1); y=y+dirs(s,2);
            end
        end
        ring=ring+1;
    end
end

function slice = determine_slice(trafficType)
    switch trafficType
        case 'embb',  slice=1;
        case 'urllc', slice=2;
        case 'mmtc',  slice=3;
        otherwise,    slice=1;
    end
end



% =========================================================================
%  MOBILITY + TRAFFIC
% =========================================================================
function [users, traffic_bits] = mobility_complete(users, cells, cfg, t)
    N = length(users);
    traffic_bits = zeros(N, 2);

    allPos = reshape([cells.position], 2, [])';
    minX = min(allPos(:,1)) - cfg.cellRadius*2;
    maxX = max(allPos(:,1)) + cfg.cellRadius*2;
    minY = min(allPos(:,2)) - cfg.cellRadius*2;
    maxY = max(allPos(:,2)) + cfg.cellRadius*2;

    for u = 1:N
        % Move
        users(u).position = users(u).position + users(u).velocity;

        % Boundary bounce
        if users(u).position(1)<minX || users(u).position(1)>maxX || ...
           users(u).position(2)<minY || users(u).position(2)>maxY
            ang = atan2(users(u).velocity(2),users(u).velocity(1)) + pi + (rand()-0.5)*pi/3;
            spd = norm(users(u).velocity);
            users(u).velocity = spd*[cos(ang),sin(ang)];
            users(u).position(1) = min(max(users(u).position(1),minX),maxX);
            users(u).position(2) = min(max(users(u).position(2),minY),maxY);
        end

        % Random direction change (correlated walk, 5% chance)
        if rand() < 0.05
            ang = atan2(users(u).velocity(2),users(u).velocity(1)) + (rand()-0.5)*pi/3;
            spd = norm(users(u).velocity);
            users(u).velocity = spd*[cos(ang),sin(ang)];
        end

        % Traffic ON/OFF
        users(u).trafficTimer = users(u).trafficTimer - 1;
        if users(u).trafficTimer <= 0
            tType = users(u).trafficType;
            b = cfg.trafficTypes.(tType).burstiness;
            if rand() < b
                users(u).trafficState = 1 - users(u).trafficState;
            end
            if users(u).trafficState == 1
                users(u).trafficTimer = max(1, round(exprnd(80)));
            else
                users(u).trafficTimer = max(1, round(exprnd(30)));
            end
        end

        % Generate bits if ON
        if users(u).trafficState == 1
            rate = cfg.trafficTypes.(users(u).trafficType).rate;
            numPkt = poissrnd(rate / 12000);   % packets per tick
            bits   = numPkt * 1500 * 8;
            traffic_bits(u,:) = [bits*0.8, bits*0.2];
            users(u).buffer = min(users(u).buffer + bits, 5e6);  % 5 Mb cap
        end
    end
end


% =========================================================================
%  CHANNEL: 3GPP TR 38.901 UMa + CDL-E + Shadow + Doppler
% =========================================================================
function [channel_gains, sinr_dl, sinr_ul] = channel_complete(users, cells, cfg, t)
    N = length(users); C = length(cells);
    Nbs = cfg.N_bs_ant; Nue = cfg.N_ue_ant;

    channel_gains = zeros(N, C, Nbs, Nue);
    sinr_dl       = zeros(N,1);
    sinr_ul       = zeros(N,1);
    rssi_dl_all   = zeros(N, C);

    for u = 1:N
        for c = 1:C
            dist  = max(norm(users(u).position - cells(c).position),1);
            angle = atan2(users(u).position(2)-cells(c).position(2), ...
                          users(u).position(1)-cells(c).position(1));

            pl_dB      = uma_path_loss_local(dist, cfg.fc_GHz);
            shadow_dB  = users(u).shadowFading(c);
            ant_gain   = antenna_gain_3d_local(angle, cfg);

            bf_gain = 0;
            if c == users(u).servingCell
                bf_gain = 10*log10(cfg.N_bs_ant);
            end

            rssi_dBm = cfg.txPower_dBm + bf_gain + ant_gain - pl_dB - shadow_dB;

            if cfg.enableFastFading
                fd_gain = cdl_e_fading_local(dist, cfg.fc_GHz, users(u).velocity, t);
                rssi_dBm = rssi_dBm + fd_gain;
            end

            rssi_lin = 10^(rssi_dBm/10);
            rssi_dl_all(u,c) = rssi_lin;

            % MIMO channel matrix
            for ab = 1:Nbs
                for au = 1:Nue
                    lambda = 3e8/(cfg.fc_GHz*1e9);
                    phi    = 2*pi*dist/lambda + 0.1*ab + 0.05*au;
                    channel_gains(u,c,ab,au) = sqrt(rssi_lin)*exp(1j*phi);
                end
            end
        end

        % SINR with full inter-cell interference
        sc      = users(u).servingCell;
        S       = rssi_dl_all(u,sc);
        I       = sum(rssi_dl_all(u,:)) - S;
        noise_W = 10^((cfg.thermalNoise_dBm-30)/10);
        sinr_lin = S / max(I+noise_W, 1e-20);
        sinr_dl(u) = min(max(10*log10(sinr_lin), -10), 35);

        % UL SINR (UE power, reciprocal path loss, BS noise figure)
        pl_ul      = uma_path_loss_local(max(norm(users(u).position - ...
                         cells(sc).position),1), cfg.fc_GHz);
        ul_rssi    = cfg.ueTxPower_dBm - pl_ul - users(u).shadowFading(sc);
        ul_rssi_W  = 10^(ul_rssi/10);
        bs_noise   = 10^((-174+10*log10(cfg.bandwidth_MHz*1e6)+5-30)/10);
        sinr_ul(u) = min(max(10*log10(ul_rssi_W/(I+bs_noise)), -10), 35);
    end
end

function pl = uma_path_loss_local(d2d, fc)
    h_bs=25; h_ut=1.5;
    d3d  = sqrt(d2d^2+(h_bs-h_ut)^2);
    dBP  = 4*h_bs*h_ut*fc*1e9/3e8;
    if d2d<=dBP
        pl_los = 28+22*log10(d3d)+20*log10(fc);
    else
        pl_los = 28+40*log10(d3d)+20*log10(fc)-9*log10(dBP^2+(h_bs-h_ut)^2);
    end
    pl_nlos = 13.54+39.08*log10(d3d)+20*log10(fc)-0.6*(h_ut-1.5);
    pl = max(max(pl_los,pl_nlos), 0);
end

function gain = antenna_gain_3d_local(angle_rad, cfg)
    az = rad2deg(angle_rad);
    bw = 65; sla = 30;
    ah = -min(12*(az/bw)^2, 20);
    ev = az - 6;
    av = -min(12*(ev/bw)^2, sla);
    gain = 8 + ah + av;
    gain = max(gain, 8-sla);
end

function fd = cdl_e_fading_local(dist, fc, velocity, t)
    taps = [0,-0.2; 20,-2.1; 40,-4.0; 70,-5.4; 110,-6.6; 160,-7.6; 230,-8.6; 330,-9.6];
    spd  = norm(velocity);
    f_d  = spd*fc*1e9/3e8;
    H    = 0;
    for k = 1:size(taps,1)
        pw  = 10^(taps(k,2)/20);
        phi = 2*pi*f_d*t*1e-3*cos(rand()*2*pi);
        H   = H + pw*exp(1j*phi);
    end
    K     = max(10-0.02*dist, 0);
    Klin  = 10^(K/10);
    los   = sqrt(Klin/(Klin+1));
    nlos  = sqrt(1/(Klin+1))*H/size(taps,1);
    fd    = min(max(20*log10(abs(los+nlos)+1e-6), -20), 15);
end


% =========================================================================
%  MASSIVE MIMO — ZF PRECODING (MU-MIMO)
% =========================================================================
function [precoding_matrices, mu_groups] = mimo_complete(channel_gains, users, cfg)
    N = length(users); C = max([users.servingCell]);
    Nbs = cfg.N_bs_ant;

    precoding_matrices = cell(C,1);
    mu_groups          = cell(C,1);

    for c = 1:C
        uList = find([users.servingCell]==c);
        if isempty(uList), continue; end

        % Select up to maxMUusers (prefer best SINR)
        numSel = min(length(uList), cfg.maxMUusers);
        uSel   = uList(randperm(length(uList), numSel));
        mu_groups{c} = uSel;

        % Build effective channel (use first UE antenna)
        H = zeros(numSel, Nbs);
        for k = 1:numSel
            H(k,:) = squeeze(channel_gains(uSel(k), c, :, 1)).';
        end

        % Regularized Zero-Forcing precoder
        regParam = 0.01 * trace(H*H') / numSel;
        if numSel <= Nbs
            W = H' / (H*H' + regParam*eye(numSel));
        else
            W = pinv(H);
        end

        % Per-column power normalization
        for k = 1:numSel
            nrm = norm(W(:,k));
            if nrm > 1e-10
                W(:,k) = W(:,k)/nrm;
            end
        end
        precoding_matrices{c} = W;
    end
end


% =========================================================================
%  LINK ADAPTATION — MCS selection from SINR / CQI
% =========================================================================
function [mcs, cqi, tbs] = link_adaptation_complete(sinr_dl, cfg)
    N   = length(sinr_dl);
    mcs = ones(N,1);
    cqi = ones(N,1);
    tbs = zeros(N,1);

    numMCS = size(cfg.mcsTable,1);

    for u = 1:N
        best = 1;
        for m = 1:numMCS
            if sinr_dl(u) >= cfg.mcsTable(m,5) + 0.5
                best = m;
            else
                break;
            end
        end
        mcs(u) = best;
        cqi(u) = min(15, ceil(best*15/numMCS));

        modOrd  = cfg.mcsTable(best,2);
        cr      = cfg.mcsTable(best,3)/1024;
        RE      = cfg.subcarriersPerRB * cfg.symbolsPerSlot * 0.86;  % ~14% OH
        tbs(u)  = modOrd * cr * RE * cfg.numRBs / 8;  % bytes per slot
    end
end


% =========================================================================
%  PROPORTIONAL FAIR SCHEDULER WITH QOS
% =========================================================================
function [rb_allocation, pf_metrics] = pf_scheduler_complete(users, sinr_dl, traffic_bits, cfg, t, metrics)
    N  = length(users);
    C  = max([users.servingCell]);
    rb_allocation = zeros(N,2);
    pf_metrics    = zeros(N,2);

    for c = 1:C
        uList = find([users.servingCell]==c);
        if isempty(uList), continue; end
        nU = length(uList);

        % Average DL throughput over past window
        avg_tput = ones(nU,1);
        if t > 5
            win = metrics.throughput_dl(uList, max(1,t-50):t-1);
            avg_tput = max(mean(win,2), 0.1);
        end

        % Instantaneous achievable rate (Shannon estimate, linear)
        inst_rate = log2(1 + 10.^(sinr_dl(uList)/10));

        % PF metric with QoS priority
        pf = zeros(nU,1);
        for k = 1:nU
            u  = uList(k);
            pr = slice_priority(users(u).slice);
            bf = min(max(users(u).buffer/1e5, 0.1), 10);  % buffer-aware
            pf(k) = (inst_rate(k)/avg_tput(k)) * pr * bf;
        end

        % Sort by PF metric
        [~,ord] = sort(pf,'descend');

        % Proportional RB allocation weighted by PF score
        pf_norm = pf(ord)/sum(pf(ord));
        for k = 1:nU
            u = uList(ord(k));
            rb_dl = max(1, round(pf_norm(k)*cfg.numRBs));
            rb_ul = max(1, round(rb_dl*0.25));  % UL 25% of DL
            rb_allocation(u,1) = min(rb_dl, cfg.numRBs);
            rb_allocation(u,2) = min(rb_ul, floor(cfg.numRBs/4));
            pf_metrics(u,1)    = pf(ord(k));
        end
    end
end

function pr = slice_priority(slice)
    switch slice
        case 2, pr=3;   % URLLC
        case 1, pr=2;   % eMBB
        case 3, pr=1;   % mMTC
        otherwise, pr=1;
    end
end


% =========================================================================
%  HARQ WITH INCREMENTAL REDUNDANCY COMBINING
% =========================================================================
function [harq_status, sinr_boost, users] = harq_complete(users, sinr_dl, mcs, cfg)
    N          = length(users);
    harq_status = zeros(N,1);  % 0=ACK 1=NACK 2=drop 3=ACK-after-retx
    sinr_boost  = sinr_dl;

    for u = 1:N
        proc = users(u).harq.nextProcess;
        mcs_idx  = mcs(u);
        sinr_thr = cfg.mcsTable(mcs_idx,5);
        margin   = sinr_dl(u) - sinr_thr;

        % BLER approximation (sigmoid-like)
        if margin >= 5,      bler = 0;
        elseif margin <= -5, bler = 0.9;
        else,                bler = 0.1 + 0.8*(1 - 1/(1+exp(margin)));
        end

        if rand() < bler
            % NACK
            rtx = users(u).harq.retxCount(proc);
            if rtx < cfg.maxHARQretx
                % IR combining: accumulate log-likelihood ratios
                % Each retx adds ~2.5 dB on average
                ir_gain = 2.5 * (rtx+1);
                users(u).harq.irBuffer(proc) = users(u).harq.irBuffer(proc) + ir_gain;
                sinr_boost(u) = sinr_dl(u) + min(users(u).harq.irBuffer(proc), 8);
                users(u).harq.retxCount(proc) = rtx + 1;
                harq_status(u) = 1;  % NACK — retransmit
            else
                % Max retx reached — drop packet
                users(u).harq.retxCount(proc) = 0;
                users(u).harq.irBuffer(proc)  = 0;
                users(u).buffer = max(users(u).buffer - 12000, 0);
                harq_status(u) = 2;  % drop
            end
        else
            % ACK
            if users(u).harq.retxCount(proc) > 0
                harq_status(u) = 3;  % success after retx
            else
                harq_status(u) = 0;  % first-tx success
            end
            users(u).harq.retxCount(proc) = 0;
            users(u).harq.irBuffer(proc)  = 0;
        end

        % Advance HARQ process round-robin
        users(u).harq.nextProcess = mod(proc, cfg.harqProcesses) + 1;
    end
end


% =========================================================================
%  THROUGHPUT COMPUTATION (DL + UL, real TBS)
% =========================================================================
function [tput_dl, tput_ul, latency] = throughput_complete(rb_allocation, mcs, tbs, harq_status, sinr_boost, cfg)
    N       = length(mcs);
    tput_dl = zeros(N,1);
    tput_ul = zeros(N,1);
    latency = zeros(N,1);

    numMCS = size(cfg.mcsTable,1);

    for u = 1:N
        if harq_status(u) == 2
            % Dropped — zero throughput this tick
            tput_dl(u) = 0;
            latency(u) = 100;
            continue;
        end

        rb_dl = rb_allocation(u,1);
        rb_ul = rb_allocation(u,2);

        mcs_idx = min(mcs(u), numMCS);
        se      = cfg.mcsTable(mcs_idx, 4);   % spectral efficiency bps/Hz
        bw_dl   = rb_dl * cfg.rbBandwidth_Hz;
        bw_ul   = rb_ul * cfg.rbBandwidth_Hz;

        % HARQ retx: count as half-rate (retransmission overhead)
        harq_factor = 1.0;
        if harq_status(u) == 1
            harq_factor = 0.5;
        elseif harq_status(u) == 3
            harq_factor = 0.75;
        end

        tput_dl(u) = (bw_dl * se * harq_factor) / 1e6;   % Mbps
        tput_ul(u) = (bw_ul * se * 0.5 * harq_factor) / 1e6;  % UL half SE

        % Latency: queuing delay proxy (1 tick = 1 ms)
        % HARQ RTT adds cfg.harqRTT ms per retransmission
        base_lat = 1.0;   % 1 ms per slot
        rtx_lat  = (harq_status(u)==1) * cfg.harqRTT;
        if tput_dl(u) > 1e-3
            latency(u) = base_lat + rtx_lat;
        else
            latency(u) = 50;  % large latency when no throughput
        end
    end
end


% =========================================================================
%  QOS ENFORCEMENT + NETWORK SLICING
% =========================================================================
function [tput_dl, tput_ul, dropped_bits] = qos_complete(tput_dl, tput_ul, users, cfg, traffic_bits)
    N            = length(users);
    dropped_bits = zeros(N,1);

    % Slice GBR thresholds (Mbps)
    gbr = [0, 1.0, 0.1];   % eMBB=0 (best effort), URLLC=1Mbps, mMTC=0.1Mbps

    for u = 1:N
        sl = users(u).slice;

        % GBR guarantee: if below min rate for URLLC/mMTC, boost with slice reserve
        if sl>=2 && tput_dl(u) < gbr(sl)
            tput_dl(u) = gbr(sl);  % guaranteed minimum
        end

        % Packet loss: if buffer overflows (already capped at 5 Mb in mobility)
        % Packets older than maxLatency are dropped
        maxLat = [100, 10, 1000];  % ms per slice
        if users(u).buffer > 0 && tput_dl(u) > 0
            bits_served = tput_dl(u) * 1e6 * 1e-3;  % bits per tick
            users(u).buffer = max(users(u).buffer - bits_served, 0);
        end

        % Mark drops when URLLC latency would be violated
        if sl==2 && tput_dl(u) < gbr(sl)*0.5
            dropped_bits(u) = traffic_bits(u,1) * 0.5;
        end
    end
end


% =========================================================================
%  DUAL CONNECTIVITY — EN-DC NSA MODE
% =========================================================================
function [tput_dl, dc_active] = dual_connectivity_complete(tput_dl, users, sinr_dl, cfg)
    N        = length(users);
    dc_active = zeros(N,1);

    if ~cfg.enableDC, return; end

    for u = 1:N
        % Enable DC if NR SINR is poor (<5 dB) — LTE anchor helps
        % OR if user is eMBB and wants aggregation
        if sinr_dl(u) < 5 || users(u).slice == 1
            % LTE anchor: simplified 20 MHz LTE at 1.8 GHz
            % Path loss to nearest cell (approximation)
            pl_lte = 128.1 + 37.6*log10(max(norm(users(u).position)*1e-3,0.01));
            lte_rssi = cfg.lteCell.txPower - pl_lte;
            lte_sinr = min(max(lte_rssi - (-100), -5), 25);  % rough SINR

            % LTE throughput (Shannon, 20 MHz, LTE efficiency ~75%)
            lte_se      = min(log2(1+10^(lte_sinr/10)) * 0.75, 5.0);
            lte_tput    = (cfg.lteCell.bandwidth * 1e6 * lte_se) / 1e6;  % Mbps

            % Aggregate NR + LTE (no double-counting of interference)
            tput_dl(u) = tput_dl(u) + lte_tput * 0.8;  % 80% efficiency in aggregation
            dc_active(u) = 1;
        end
    end
end


% =========================================================================
%  HANDOVER — A3 EVENT, HYSTERESIS, TTT, X2 DELAY
% =========================================================================
function [users, ho_count, x2_delay] = handover_complete(users, cells, sinr_dl, cfg, t)
    N        = length(users);
    ho_count = 0;
    x2_delay = zeros(N,1);

    % Recompute per-cell RSSI for HO decisions
    % (use SINR as proxy — best SINR = best cell)
    for u = 1:N

        % Count-down X2 timer if handover in progress
        if users(u).ho.x2Timer > 0
            users(u).ho.x2Timer  = users(u).ho.x2Timer - 1;
            x2_delay(u)          = users(u).ho.x2Timer;
            continue;  % user is mid-handover, don't re-evaluate
        end

        sc = users(u).servingCell;

        % Estimate RSSI per cell from distance (for A3 event)
        rssi_per_cell = zeros(1, length(cells));
        for c = 1:length(cells)
            d = max(norm(users(u).position - cells(c).position),1);
            pl = uma_path_loss_local(d, cfg.fc_GHz);
            rssi_per_cell(c) = cfg.txPower_dBm - pl - users(u).shadowFading(c);
        end

        [bestRSSI, bestCell] = max(rssi_per_cell);
        servRSSI = rssi_per_cell(sc);

        % A3 event condition: target > serving + hysteresis + A3offset
        a3_condition = (bestRSSI - servRSSI) > (cfg.hysteresis_dB + cfg.a3Offset_dB);

        if bestCell ~= sc && a3_condition
            % Start or continue TTT
            if isequal(users(u).ho.targetCell, bestCell)
                users(u).ho.tttCounter = users(u).ho.tttCounter + 1;
            else
                % New target — restart TTT
                users(u).ho.targetCell  = bestCell;
                users(u).ho.tttCounter  = 1;
            end

            % TTT expired — execute handover
            if users(u).ho.tttCounter >= cfg.TTT_ticks
                % Start X2 timer (service interruption)
                users(u).ho.x2Timer    = cfg.x2Delay_ticks;
                users(u).servingCell   = bestCell;
                users(u).ho.tttCounter = 0;
                users(u).ho.targetCell = [];
                % Re-randomize shadow fading on new link
                users(u).shadowFading(bestCell) = cfg.shadowStd * randn();
                ho_count = ho_count + 1;
            end
        else
            % Condition gone — reset TTT
            users(u).ho.tttCounter = 0;
            users(u).ho.targetCell = [];
        end
    end
end


% =========================================================================
%  STORE METRICS
% =========================================================================
function metrics = store_metrics(metrics, tput_dl, tput_ul, sinr_dl, sinr_ul, ...
    mcs, cqi, harq_status, ho_count, rb_allocation, mu_groups, dc_active, ...
    latency, dropped_bits, pf_metrics, t)

    metrics.throughput_dl(:,t) = tput_dl;
    metrics.throughput_ul(:,t) = tput_ul;
    metrics.sinr_dl(:,t)       = sinr_dl;
    metrics.sinr_ul(:,t)       = sinr_ul;
    metrics.mcs(:,t)           = mcs;
    metrics.cqi(:,t)           = cqi;
    metrics.harq_status(:,t)   = harq_status;
    metrics.handovers(t)       = ho_count;
    metrics.dc_active(:,t)     = dc_active;
    metrics.latency(:,t)       = latency;
    metrics.dropped_bits(:,t)  = dropped_bits;
    metrics.pf_metric(:,t)     = pf_metrics(:,1);

    % RB utilisation per cell
    C = size(metrics.rb_util,1);
    for c = 1:C
        metrics.rb_util(c,t) = mean(rb_allocation(:,1));
    end

    % MU-MIMO group size
    for c = 1:length(mu_groups)
        if ~isempty(mu_groups{c})
            metrics.mu_size(c,t) = length(mu_groups{c});
        end
    end
end


% =========================================================================
%  LIVE DISPLAY
% =========================================================================
function update_live_display(hLive, metrics, users, cells, t, T, totalHO, cfg)
    if ~ishandle(hLive), return; end
    figure(hLive); clf;

    N = length(users); C = length(cells);
    cmap = lines(C);

    % -- Subplot 1: Network topology --
    subplot(2,3,[1,4]);
    hold on;
    theta = linspace(0, 2*pi, 7);
    for c = 1:C
        cx = cells(c).position(1); cy = cells(c).position(2);
        hx = cx + cfg.cellRadius*cos(theta);
        hy = cy + cfg.cellRadius*sin(theta);
        fill(hx, hy, cmap(c,:), 'FaceAlpha',0.08, 'EdgeColor',cmap(c,:), 'LineWidth',1.2);
        plot(cx, cy, '^', 'MarkerSize',10, 'MarkerFaceColor',cmap(c,:), 'MarkerEdgeColor','k');
        text(cx, cy+cfg.cellRadius*0.15, sprintf('gNB%d',c), 'FontSize',7, ...
            'HorizontalAlignment','center','Color',cmap(c,:)*0.7);
    end
    for u = 1:N
        sc  = users(u).servingCell;
        col = cmap(sc,:);
        ms  = 4 + users(u).slice;  % marker size by slice
        plot(users(u).position(1), users(u).position(2), 'o', ...
            'MarkerSize',ms, 'MarkerFaceColor',col, 'MarkerEdgeColor',col);
        if users(u).ho.x2Timer > 0
            plot(users(u).position(1), users(u).position(2), 'o', ...
                'MarkerSize',ms+5, 'MarkerEdgeColor',[1,0.5,0], ...
                'MarkerFaceColor','none', 'LineWidth',1.5);
        end
    end
    hold off; axis equal; grid on;
    title(sprintf('Network t=%d/%d | HO=%d', t, T, totalHO));
    xlabel('X (m)'); ylabel('Y (m)');

    % -- Subplot 2: DL Throughput over time --
    subplot(2,3,2);
    t_ax = 1:t;
    avg_dl = mean(metrics.throughput_dl(:,1:t),1);
    plot(t_ax, avg_dl, 'b-', 'LineWidth',1.5);
    title('Avg DL Throughput'); xlabel('Tick (ms)'); ylabel('Mbps'); grid on;

    % -- Subplot 3: SINR distribution --
    subplot(2,3,3);
    sinr_now = metrics.sinr_dl(:,t);
    histogram(sinr_now, 12, 'FaceColor',[0.2,0.7,0.4], 'EdgeColor','w');
    title(sprintf('SINR @ t=%d (mean=%.1fdB)',t,mean(sinr_now)));
    xlabel('SINR (dB)'); ylabel('Users'); grid on;

    % -- Subplot 4: Latency --
    subplot(2,3,5);
    avg_lat = mean(metrics.latency(:,1:t),1);
    plot(t_ax, avg_lat, 'r-', 'LineWidth',1.5);
    title('Avg Latency'); xlabel('Tick (ms)'); ylabel('ms'); grid on;

    % -- Subplot 5: Handovers --
    subplot(2,3,6);
    bar(t_ax, metrics.handovers(1:t), 'FaceColor',[0.85,0.55,0.15], 'EdgeColor','none');
    title('Handovers per tick'); xlabel('Tick'); ylabel('Count'); grid on;

    sgtitle(sprintf('5G NR Live — t=%d | DL=%.1fMbps | UL=%.1fMbps | SINR=%.1fdB', ...
        t, mean(avg_dl), mean(mean(metrics.throughput_ul(:,1:t),1)), mean(sinr_now)), ...
        'FontWeight','bold');
    drawnow limitrate;
end


% =========================================================================
%  FINAL REPORT (console)

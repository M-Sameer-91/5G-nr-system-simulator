clc; clear; close all;

% Load configuration
cfg = config_complete();

% Initialize network
[cells, users] = init_network_complete(cfg);

% Pre-allocate metrics
[T, N, C] = deal(cfg.simTime, cfg.numUsers, cfg.numCells);
metrics = initialize_metrics(N, T, C);

% Live visualization
hLive = figure('Name','5G NR Live Monitor','Position',[50 50 1400 800]);
totalHO = 0;

fprintf('\n=== 5G NR COMPLETE SIMULATION ===\n');
fprintf('Starting %d ticks with %d users, %d cells\n\n', T, N, C);

% Main simulation loop
for t = 1:T
    % 1. Mobility and traffic
    [users, traffic_bits] = mobility_complete(users, cells, cfg, t);

    % 2. Channel with fast fading (CDL-E)
    [channel_gains, sinr_dl, sinr_ul] = channel_complete(users, cells, cfg, t);

    % 3. Massive MIMO with ZF precoding
    [precoding_matrices, mu_groups] = mimo_complete(channel_gains, users, cfg);

    % 4. Link adaptation with real MCS/CQI
    [mcs, cqi, tbs] = link_adaptation_complete(sinr_dl, cfg);

    % 5. Proportional Fair scheduler with QoS
    [rb_allocation, pf_metrics] = pf_scheduler_complete(users, sinr_dl, traffic_bits, cfg, t, metrics);

    % 6. HARQ with IR combining
    [harq_status, sinr_boost, users] = harq_complete(users, sinr_dl, mcs, cfg);

    % 7. Throughput with real TBS
    [tput_dl, tput_ul, latency] = throughput_complete(rb_allocation, mcs, tbs, harq_status, sinr_boost, cfg);

    % 8. QoS enforcement with slicing
    [tput_dl, tput_ul, dropped_bits] = qos_complete(tput_dl, tput_ul, users, cfg, traffic_bits);

    % 9. Dual connectivity (EN-DC NSA)
    [tput_dl, dc_active] = dual_connectivity_complete(tput_dl, users, sinr_dl, cfg);

    % 10. Handover with X2 delay
    [users, ho_count, x2_delay] = handover_complete(users, cells, sinr_dl, cfg, t);
    totalHO = totalHO + ho_count;

    % Store metrics
    metrics = store_metrics(metrics, tput_dl, tput_ul, sinr_dl, sinr_ul, ...
        mcs, cqi, harq_status, ho_count, rb_allocation, mu_groups, dc_active, ...
        latency, dropped_bits, pf_metrics, t);

    % Live update
    if mod(t, max(1, floor(T/100))) == 0 || t == 1
        update_live_display(hLive, metrics, users, cells, t, T, totalHO, cfg);
    end

    % Progress
    if mod(t, max(1, floor(T/20))) == 0
        fprintf('Progress: %3d%% | DL: %.1f Mbps | UL: %.1f Mbps | HO: %d | Lat: %.1f ms\n', ...
            round(100*t/T), mean(tput_dl), mean(tput_ul), totalHO, mean(latency));
    end
end

fprintf('\n=== Simulation Complete ===\n');
generate_final_report(metrics, cfg, totalHO);
generate_all_plots(metrics, cfg, cells);


